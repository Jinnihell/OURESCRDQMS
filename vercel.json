<?php
// 1. Initialize mysqli object
$conn = mysqli_init();

// 2. I-set ang SSL bago ang connection (Required for Aiven)
mysqli_ssl_set($conn, NULL, NULL, NULL, NULL, NULL); 

// 3. Kunin ang credentials mula sa Environment Variables ng Vercel
$host = getenv('DB_HOST');
$user = getenv('DB_USER');
$pass = getenv('DB_PASS');
$db   = getenv('DB_NAME');
$port = getenv('DB_PORT');

// 4. Gamitin ang mysqli_real_connect (Huwag 'new mysqli')
$success = mysqli_real_connect(
    $conn, 
    $host, 
    $user, 
    $pass, 
    $db, 
    (int)$port
);

if (!$success) {
    // Para makita mo ang eksaktong error sa Vercel logs
    error_log("Connection failed: " . mysqli_connect_error());
    die("Database connection error. Please try muli mamaya.");
}

$conn->set_charset("utf8mb4");
?>
